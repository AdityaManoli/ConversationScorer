# Ahoum Evaluation Environment Configuration
# Copy this file to '.env' and modify as needed.

# The root endpoint for your native Ollama server or compatible remote inferences.
OLLAMA_BASE_URL=http://localhost:11434

# The specific model tag you wish to execute evaluations on.
# Highly recommended to use Llama 3.1 8B due to the massive 128k token context window limit.
OLLAMA_MODEL=llama3.1:8b

# The number of facets to evaluate per single LLM prompting loop.
# 150 natively leverages Llama 3.1 8B. If you are experiencing JSON parsing errors using
# smaller context models, downscale this to 50 or 20.
BATCH_SIZE=150
